# Browser profiles / login sessions (never commit — contain cookies)
# The default profile lives outside the repo (~/.local/share/chatgpt-proxy/),
# but ignore any local ones too.
*_profile/
.cloak-profile/
cloak-profile/
profile_config.txt

# uv / venv / env
.venv/
.env

# Raw network captures (contain auth tokens / cookies — never commit)
*.har
docs/databricks_har/

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
build/
dist/
*.egg-info/
*.egg

# Claude Code local (personal, machine-specific) settings — never commit
.claude/settings.local.json

# IDE / OS
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
